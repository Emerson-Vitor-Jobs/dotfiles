
allow_remote_control yes
listen_on unix:/tmp/kitty

# Kitty configuration to use Fish shell
shell /usr/bin/fish
allow_remote_control yes
listen_on unix:/tmp/kitty
# Basic Kitty settings
font_family      JetBrainsMono Nerd Font
bold_font        auto
italic_font      auto
bold_italic_font auto

# Window settings
window_padding_width 4
window_margin_width 0
window_border_width 1pt

map ctrl+shift+h no_op
map ctrl+shift+j no_op
map ctrl+shift+k no_op
map ctrl+shift+l no_op

# Opcional: Mapeia Alt+h/j/k/l para navegar entre abas
map alt+h previous_tab
map alt+l next_tab
# Opacidade da janela em foco (mais sólida)
# Opacidade das janelas inativas (mais transparentes)
# Colors (gruvbox dark)
# foreground              #ebdbb2
# background              #282828
# selection_foreground    #282828
# selection_background    #ebdbb2

# Cursor colors
# cursor                  #ebdbb2
# cursor_text_color       #282828

# URL underline color when hovering with mouse
# url_color               #83a598

# Kitty window border colors
# active_border_color     #b16286
# inactive_border_color   #665c54
# bell_border_color       #fabd2f

# OS Window titlebar colors
# wayland_titlebar_color  #282828

# Tab bar colors
# active_tab_foreground   #282828
# active_tab_background   #ebdbb2
# inactive_tab_foreground #ebdbb2
# inactive_tab_background #3c3836
# tab_bar_background      #282828

# Colors for marks (marked text in the terminal)
# mark1_foreground #282828
# mark1_background #83a598
# mark2_foreground #282828
# mark2_background #b16286
# mark3_foreground #282828
# mark3_background #fabd2f

# The 16 terminal colors

# black
# color0 #282828
# color8 #928374

# red
# color1 #cc241d
# color9 #fb4934

# green
# color2  #98971a
# color10 #b8bb26

# yellow
# color3  #d79921
# color11 #fabd2f

# blue
# color4  #458588
# color12 #83a598

# magenta
# color5  #b16286
# color13 #d3869b

# cyan
# color6  #689d6a
# color14 #8ec07c

# white
# color7  #a89984
# color15 #ebdbb2

# BEGIN_KITTY_THEME
# Bluloco Light
include current-theme.conf
# END_KITTY_THEME

